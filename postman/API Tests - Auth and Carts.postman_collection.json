      "name": "01 - Auth",
      "item": [
        {
          "name": "Auth success",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "(function () {",
                  "    const data = pm.response.json();",
                  "    ",
                  "    pm.test('Статус код 200 при успешной регистрации', function () {",
                  "        pm.response.to.have.status(200);",
                  "    });",
                  "    ",
                  "    pm.test('В ответе есть id и token пользователя', function () {",
                  "        pm.expect(data.id, 'id').to.be.a('number');",
                  "        pm.expect(data.username, 'username').to.eql(pm.environment.get('username'));",
                  "        pm.expect(data.email, 'email').to.be.a('string').and.to.include('@');",
                  "        pm.expect(data.accessToken, 'accessToken').to.be.a('string').and.not.empty;",
                  "        pm.expect(data.refreshToken, 'refreshToken').to.be.a('string').and.not.empty;",
                  "    });",
                  "    ",
                  "    if (pm.response.code === 200 && data.accessToken) {",
                  "        pm.environment.set('accessToken', data.accessToken);",
                  "        pm.environment.set('refreshToken', data.refreshToken);",
                  "        pm.environment.set('userId', String(data.id));",
                  "    }",
                  "})();"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\",\n  \"expiresInMins\": 30\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
