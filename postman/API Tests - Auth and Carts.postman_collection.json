        {
          "name": "User carts",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "(function () {",
                  "    const data = pm.response.json();",
                  "    const expectedUserId = Number(pm.environment.get('userId'));",
                  "    ",
                  "    pm.test('Статус код 200 при получении cart', function () {",
                  "        pm.response.to.have.status(200);",
                  "    });",
                  "    ",
                  "    pm.test('Ответ содержит метаданные коллекции корзин', function () {",
                  "        pm.expect(data.carts, 'carts').to.be.an('array');",
                  "        pm.expect(data.total, 'total').to.be.a('number');",
                  "        pm.expect(data.skip, 'skip').to.be.a('number');",
                  "        pm.expect(data.limit, 'limit').to.be.a('number');",
                  "    });",
                  "    ",
                  "    pm.test('Каждый возвращенный товар принадлежит запрошенному пользователю', function () {",
                  "        data.carts.forEach(cart => pm.expect(cart.userId, `cart ${cart.id} userId`).to.eql(expectedUserId));",
                  "    });",
                  "    ",
                  "    if (Array.isArray(data.carts) && data.carts.length > 0) {",
                  "        pm.environment.set('cartId', String(data.carts[0].id));",
                  "    }",
                  "})();"
                ],
